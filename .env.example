# 达累斯萨拉姆 WhatsApp 翻译后端 — 环境变量样例
# 本地开发：复制本文件为 .env 并填入真实值
# Railway 部署：在 Variables 页面逐个添加
# ===================================================================

# ===================================================================
# Provider 选择
# ===================================================================
# 默认：DeepSeek 主，OpenAI 备。两个 Key 都建议填，少一个就没有自动容灾。
#   SEMA_PRIMARY_PROVIDER=deepseek  → 默认走 DeepSeek，失败自动切 OpenAI
#   SEMA_PRIMARY_PROVIDER=openai      → 反过来
SEMA_PRIMARY_PROVIDER=deepseek

# 必填（至少一个）：API Keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here

# 可选：默认 DeepSeek 模型
#   deepseek-chat      — 通用对话/翻译（默认推荐）
#   deepseek-reasoner  — 推理更强，更慢更贵
SEMA_DEEPSEEK_MODEL=deepseek-chat

# 可选：网关地址
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：本地开发端口（Railway 会自动注入 PORT）
PORT=3000

# 可选：用户名白名单（逗号分隔）。空 = 完全放行
# 例：SEMA_ALLOWED_USERS=alice,bob,charlie
SEMA_ALLOWED_USERS=

# 可选：管理员用户名（逗号分隔），可访问 /api/admin/usage 和 /admin 控制台
# 例：SEMA_ADMIN_USERS=admin
# 留空 = 任何已认证用户均可访问管理接口（不推荐生产环境）
SEMA_ADMIN_USERS=

# 可选：扩展未填用户名时的默认统计名（仅 SEMA_ALLOWED_USERS 未启用时生效）
# SEMA_DEFAULT_USER=_default

# 例：SEMA_USER_QUOTAS={"alice":500000,"bob":200000}
# 例：SEMA_USER_QUOTAS=alice:500000,bob:200000
# 0 或不设置 = 该用户无限制
SEMA_USER_QUOTAS=

# 准确率优先（默认 true）：更长 prompt、更多上下文、关闭本地快路径、默认 expert 模式
# SEMA_ACCURACY_PRIORITY=false 可回到省 token 模式
# SEMA_LOCAL_FAST=true 可重新开启 0-token 本地快路径（可能降低短句准确率）
SEMA_ACCURACY_PRIORITY=true

# 可选：默认翻译模式 slim | expert（未设置时 accuracy 模式默认 expert）
# SEMA_TRANSLATE_DEFAULT_MODE=expert

# 可选：是否叠加完整行业词库 local-glossary.json（默认只用 colloquial-glossary.json 口语库）
# SEMA_ENABLE_GLOSSARY=true

# 可选：是否允许昂贵 OpenAI 模型（gpt-4o 等）
SEMA_ALLOW_PREMIUM_MODELS=false
